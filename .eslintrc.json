{
  "root": true,
  "extends": ["@salesforce/eslint-config-lwc/recommended"],
  "overrides": [
    {
      "files": ["*.test.js"],
      "rules": {
        "@lwc/lwc/no-unexpected-wire-adapter-usages": "off"
      },
      "env": {
        "node": true,
        "jest": true
      }
    },
    {
      "files": ["**/aura/**/*.js"],
      "extends": ["@salesforce/eslint-config-lwc/base"],
      "plugins": ["@salesforce/aura"]
    }
  ]
}
