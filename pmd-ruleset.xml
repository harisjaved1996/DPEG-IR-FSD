<?xml version="1.0" encoding="UTF-8" ?>
<ruleset
    name="DPEG Apex Ruleset"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             http://pmd.sourceforge.net/ruleset_2_0_0.xsd"
>

  <description>
    PMD Apex ruleset for DPEG.
    Aligns with ARCHITECTURE.md: with sharing, WITH USER_MODE, handler pattern,
    no SOQL/DML in loops, bulkification, 90% test coverage target.
  </description>

  <!-- Best Practices -->
  <rule ref="category/apex/bestpractices.xml">
    <exclude name="ApexUnitTestClassShouldHaveAsserts" />
  </rule>
  <rule ref="category/apex/bestpractices.xml/ApexUnitTestClassShouldHaveAsserts">
    <priority>2</priority>
  </rule>

  <!-- Performance -->
  <rule ref="category/apex/performance.xml" />

  <!-- Security -->
  <rule ref="category/apex/security.xml" />

  <!-- Error Prone -->
  <rule ref="category/apex/errorprone.xml">
    <exclude name="ApexCSRF" />
  </rule>

  <!-- Design -->
  <rule ref="category/apex/design.xml">
    <exclude name="ExcessivePublicCount" />
    <exclude name="CognitiveComplexity" />
  </rule>
  <rule ref="category/apex/design.xml/CognitiveComplexity">
    <properties>
      <property name="classReportLevel" value="60" />
      <property name="methodReportLevel" value="20" />
    </properties>
  </rule>
  <rule ref="category/apex/design.xml/ExcessiveParameterList">
    <properties>
      <property name="minimum" value="5" />
    </properties>
  </rule>

  <!-- Code Style -->
  <rule ref="category/apex/codestyle.xml">
    <exclude name="MethodNamingConventions" />
    <exclude name="ClassNamingConventions" />
  </rule>

  <!-- Documentation -->
  <rule ref="category/apex/documentation.xml/ApexDoc">
    <priority>3</priority>
    <properties>
      <property name="reportPrivate" value="false" />
      <property name="reportProtected" value="false" />
      <property name="reportMissingDescription" value="true" />
    </properties>
  </rule>
</ruleset>
