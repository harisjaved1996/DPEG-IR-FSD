# Standard ignores
.forceignore

# Non-Salesforce project directories - exclude from all deployments
docs/
scripts/

# IDE and OS artifacts
.vscode/
.DS_Store
*.swp
*~

# Node modules
node_modules/

# Scratch org config (not deployable metadata)
config/
**/jsconfig.json
**/.eslintrc.json

# LWC Jest tests and tooling (not deployable metadata)
**/__tests__/**
**/*.test.js
**/__mocks__/**