<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>DocuSign Wizard Access</label>
    <description>Least-privilege access to the DocuSign Send for E-Signature wizard. Grants execute access to the wizard Apex entry points only. Object/record access is governed by the user's existing profile and sharing.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>DocuSignWizardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DocuSignBulkSendService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DocuSignBulkSendQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DocuSignWizardDTO</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ContactSelector</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DocuSignDocumentSelector</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
