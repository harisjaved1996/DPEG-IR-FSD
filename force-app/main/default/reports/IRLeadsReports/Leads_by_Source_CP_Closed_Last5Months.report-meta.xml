    <description>Count of leads with status Create Profile or Closed, created in the last 5 months (rolling 150-day window, includes the current month), grouped by Lead Source (channel). Feeds the New Investors by Channel widget on the Investor Dashboard.</description>
    <filter>
        <criteriaItems>
            <column>STATUS</column>
            <columnToColumn>false</columnToColumn>
            <isUnlocked>true</isUnlocked>
            <operator>equals</operator>
            <value>Create_Profile,Closed</value>
        </criteriaItems>
        <criteriaItems>
            <column>LEAD_SOURCE</column>
            <columnToColumn>false</columnToColumn>
            <isUnlocked>true</isUnlocked>
            <operator>equals</operator>
            <value>Web,Phone,Other</value>
        </criteriaItems>
    </filter>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>LEAD_SOURCE</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <name>Leads by Source - Last 5 Months</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
