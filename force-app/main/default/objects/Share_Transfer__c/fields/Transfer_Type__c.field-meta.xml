    <inlineHelpText>Partial transfers move some units; Full transfers move the entire position.</inlineHelpText>
    <type>Picklist</type>
    <trackHistory>true</trackHistory>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Partial</fullName>
                <default>true</default>
                <label>Partial</label>
            </value>
            <value>
                <fullName>Full</fullName>
                <default>false</default>
                <label>Full</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
