<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Portal_Invite_Status__c</fullName>
    <label>Portal Invite Status</label>
    <description>Whether the investor portal invitation has been sent to this onboarding lead.</description>
    <inlineHelpText>Pending until the portal invite is sent; set to Invited once the invitation has gone out.</inlineHelpText>
    <type>Picklist</type>
    <required>false</required>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Invited</fullName>
                <default>false</default>
                <label>Invited</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
