    <inlineHelpText>Tracks the payment from Pending through Posted/Processed, or Failed/Returned; Cheque Mailed for paper cheques.</inlineHelpText>
    <type>Picklist</type>
    <required>false</required>
    <trackHistory>true</trackHistory>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Posted</fullName>
                <default>false</default>
                <label>Posted</label>
            </value>
            <value>
                <fullName>Processed</fullName>
                <default>false</default>
                <label>Processed</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
            <value>
                <fullName>Returned</fullName>
                <default>false</default>
                <label>Returned</label>
            </value>
            <value>
                <fullName>Cheque Mailed</fullName>
                <default>false</default>
                <label>Cheque Mailed</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
