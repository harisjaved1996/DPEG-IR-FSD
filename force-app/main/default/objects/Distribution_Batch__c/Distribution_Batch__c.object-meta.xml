<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Header record grouping Distributions processed together (quarterly, monthly, or exit). Carries batch totals maintained by Phase C automation.</description>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Distribution Batch</label>
    <nameField>
        <label>Batch Number</label>
        <type>AutoNumber</type>
        <displayFormat>DB-{000}</displayFormat>
        <startingNumber>18</startingNumber>
    </nameField>
    <pluralLabel>Distribution Batches</pluralLabel>
    <sharingModel>Private</sharingModel>
    <visibility>Public</visibility>
    <compactLayoutAssignment>Distribution_Batch_Compact</compactLayoutAssignment>
</CustomObject>
