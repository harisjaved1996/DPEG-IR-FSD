<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Confirmed, funded investor position in an Offering. Parent (master) of Contributions and Distributions, and the source of portfolio cash-flow roll-ups.</description>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Investment</label>
    <nameField>
        <label>Investment Number</label>
        <type>AutoNumber</type>
        <displayFormat>INV-{0000}</displayFormat>
        <startingNumber>1000</startingNumber>
    </nameField>
    <pluralLabel>Investments</pluralLabel>
    <sharingModel>Private</sharingModel>
    <visibility>Public</visibility>
    <compactLayoutAssignment>Investment_Compact</compactLayoutAssignment>
</CustomObject>
